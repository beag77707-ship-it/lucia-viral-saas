generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  name            String?
  image           String?
  plan            String    @default("BASIC")
  heygenAvatarId  String?
  heygenVoiceId   String?
  heygenVideoUrl  String?
  heygenStatus    String    @default("IDLE")
  selectedScenarios String?   // Guardaremos ["office", "nature", ...] como JSON
  videoCredits    Int       @default(5)
  scriptsGeneratedMonth Int @default(0)
  carouselsGeneratedMonth Int @default(0)
  generationResetDate DateTime @default(now())
  projects        Project[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  niche       String
  competitors String
  resultJSON  String?
  pdfUrl      String?
  videoUrl    String?
  status      String   @default("IDLE")
  videos      Video[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Video {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  title       String?
  script      String?
  videoUrl    String?
  scenario    String?
  carouselJson String?
  status      String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  errorMessage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
