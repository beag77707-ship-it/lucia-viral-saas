generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  image     String?
  plan      String    @default("BASIC")
  heygenAvatarId String?
  heygenVideoUrl String?
  heygenStatus String    @default("IDLE")
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  niche       String
  competitors String
  resultJSON  String?
  pdfUrl      String?
  videoUrl    String?
  status      String   @default("IDLE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


