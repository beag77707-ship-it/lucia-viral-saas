generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  plan      Plan      @default(BASIC)
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  niche       String
  competitors Json
  resultJSON  Json?
  pdfUrl      String?
  videoUrl    String?
  status      Status   @default(IDLE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Plan {
  BASIC
  PRO
}

enum Status {
  IDLE
  PROCESSING
  COMPLETED
  FAILED
}
