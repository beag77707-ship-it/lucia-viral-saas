    {
      "parameters": {
        "jsCode": "const combined = $input.all().map((i, index) => {\n  let transcript = 'Sin texto reconocido';\n  if (i.json.text) transcript = i.json.text;\n  \n  return `--- VIDEO VIRAL ${index + 1} --->\\n` +\n         `URL Original: ${i.json.videoUrl}\\n` +\n         `Vistas: ${i.json.videoViewCount}\\n` +\n         `Likes: ${i.json.likesCount}\\n` +\n         `Score Viral: ${i.json.viralScore}\\n` +\n         `TEXTO HABLADO COPIADO DE SU VOZ: \\\"${transcript}\\\"\\n`;\n}).join(\"\\n\\n\");\n\nreturn { json: { corpus: combined } };"
      },
      "id": "30a77e13-0feb-4a23-b36d-c79aa9687cfb",
      "name": "Code: Aggregate Text",
