    {
      "parameters": {
        "jsCode": "let itemsRaw = $input.all().map(i => i.json);\n\n// Si por alguna razón n8n agrupa la respuesta en array, lo desempaquetamos\nif(itemsRaw.length === 1 && Array.isArray(itemsRaw[0])) {\n  itemsRaw = itemsRaw[0];\n}\n\n// solo reels (videos)\nconst reels = itemsRaw.filter(p => p.type === \"Video\" && p.videoUrl);\n\n// calcular score viral\nconst sorted = reels\n  .map(p => ({\n    ...p,\n    viralScore: (\n      (p.videoViewCount || 0) * 0.6 +\n      (p.likesCount || 0) * 0.3 +\n      (p.commentsCount || 0) * 0.1\n    )\n  }))\n  .sort((a, b) => b.viralScore - a.viralScore)\n  .slice(0, 5); // top 5\n\nreturn sorted.map(r => ({ json: r }));"
      },
      "id": "b2b1642c-d876-4676-b025-23e71fd5ef03",
      "name": "Code: Filter Viral Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        896,
        0
      ]
    },
    {
